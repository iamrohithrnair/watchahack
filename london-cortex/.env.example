# London Cortex Configuration
# Copy this file to .env and fill in the values

# === REQUIRED ===
# Get your Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# === OPTIONAL: Transport ===
# TfL Unified API (free at https://api.tfl.gov.uk/)
TFL_APP_KEY=
TFL_APP_ID=
# Bus data (https://data.bus-data.dft.gov.uk/)
BODS_API_KEY=
# TomTom traffic (https://developer.tomtom.com/)
TOMTOM_API_KEY=
# Waze partner feed
WAZE_FEED_URL=
# Uber rideshare
UBER_SERVER_TOKEN=

# === OPTIONAL: Air Quality ===
# Google Air Quality API
GOOGLE_AQ_API_KEY=
# PurpleAir sensors
PURPLEAIR_API_KEY=
# OpenAQ
OPENAQ_API_KEY=

# === OPTIONAL: Events ===
# PredictHQ events
PREDICTHQ_API_KEY=

# === OPTIONAL: LLM Configuration ===
# Provider: "gemini" (default) or "glm"
LLM_PROVIDER=gemini
LLM_FLASH_MODEL=gemini-2.0-flash
LLM_PRO_MODEL=gemini-2.5-pro
